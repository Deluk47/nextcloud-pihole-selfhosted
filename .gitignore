# --------- Secrets and environment ---------
# Ignore all .env files (real configs with secrets)
.env
**/.env
.env.*
*.env.local
*.secret
*secret*
*secrets*

# --------- Docker runtime data (by service) ---------
# Nextcloud / Caddy reverse proxy
nextcloud/reverse-proxy/caddy_data/
nextcloud/reverse-proxy/caddy_config/
nextcloud/reverse-proxy/caddy_certs/
nextcloud/reverse-proxy/caddy_sites/

# Pi-hole runtime data
pihole/etc-pihole/
pihole/etc-dnsmasq.d/

# --------- Local override / debug files ---------
docker-compose.override.yml
compose.override.yml
docker-compose.*.local.yml

# --------- Logs ---------
*.log
logs/

# --------- Editors / IDEs ---------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------- Misc system junk ---------
**/__pycache__/
*.pyc
