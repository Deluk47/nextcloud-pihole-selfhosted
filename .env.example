cd ~/pihole

# Create a private .env with your real values
cat > .env << 'EOF'
TZ=Europe/London
FTLCONF_webserver_api_password=YOUR_REAL_PASSWORD_HERE
EOF

# Create a public example file (committed to Git) without the real password
cat > .env.example << 'EOF'
TZ=Europe/London
FTLCONF_webserver_api_password=changeme
EOF
