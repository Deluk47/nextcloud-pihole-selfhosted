{
    local_certs
}

# Caddy reads the environment variable from your ignored .env file automatically
{$NEXTCLOUD_DOMAIN} {
    tls internal

    handle_path /standalone-signaling/* {
        reverse_proxy 127.0.0.1:3479 {
            flush_interval -1
        }
    }

    handle /cool/* {
        reverse_proxy 127.0.0.1:9980
    }

    handle {
        reverse_proxy 127.0.0.1:11000
    }
}
