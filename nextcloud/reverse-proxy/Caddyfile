{
    local_certs
}

{$NEXTCLOUD_DOMAIN} {
    tls internal

    # Nextcloud Talk (HPB / Signaling)
    handle_path /standalone-signaling/* {
        reverse_proxy nextcloud-aio-talk:3479 {
            flush_interval -1
        }
    }

    # Collabora Online / Office
    handle /cool/* {
        reverse_proxy nextcloud-aio-collabora:9980
    }

    # Main Nextcloud Web Server
    handle {
        reverse_proxy nextcloud-aio-apache:11000
    }
}
